# ============================================================
# OmniAgent v8.5 — .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
*.whl
.venv/
venv/
env/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ── Runtime / Generated ─────────────────────────────────────
# Database (contains user data, encrypted messages)
omni_data.db
omni_data.db-wal
omni_data.db-shm
omni_data.db-journal

# Session state
omni_session.json

# Encryption key (NEVER commit — unique per installation)
.omni_key

# Tunnel URL (ephemeral)
.tunnel_url

# Agent working files
plan.md
memory.md

# ── Uploads (user-generated content) ────────────────────────
uploads/
worker_outputs/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Secrets / Environment ───────────────────────────────────
.env
.env.local
.env.production
.env.*.local
credentials.json
client_secret*.json

# ── BitNet (1.2GB model + compiled binaries) ────────────────
bitnet/model/
bitnet/llama-server
bitnet/llama-cli
# Keep bitnet/start.sh (small script)

# ── Piper Voice Models (downloaded separately) ──────────────
*.onnx
# Keep .onnx.json config files (tiny)
!src/**/*.onnx

# ── Android ─────────────────────────────────────────────────
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captures/
android/.externalNativeBuild/
android/.cxx/

# Android signing
*.jks
*.keystore
android/app/*.apk

# Standalone APK builds at repo root
*.apk

# ── Gradle ──────────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# ── Tauri / Desktop ─────────────────────────────────────────
desktop/src-tauri/target/
desktop/node_modules/
desktop/package-lock.json

# ── VS Code Extension ──────────────────────────────────────
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/*.vsix

# ── Node (frontend tooling) ────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Fine-tuning data ────────────────────────────────────────
finetune_data/

# ── ML Models (too large for git) ───────────────────────────
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.h5
*.tflite
# Exception: keep Android assets if bundled
!android/app/src/main/assets/**

# ── RAG / Vector index ─────────────────────────────────────
chromadb/
faiss_index/
*.faiss
*.index

# ── IDE / Editor ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Docker ───────────────────────────────────────────────────
docker/data/

# ── Testing / Coverage ─────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
.tox/
.nox/

# ── Build artifacts ─────────────────────────────────────────
dist/
build/
*.deb
*.rpm
*.msi
*.exe
*.AppImage
!mcp_server.py
!omni_agent.py
!gpu_worker.py
!setup-gpu-worker-wsl.ps1

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.rej
.cache/
