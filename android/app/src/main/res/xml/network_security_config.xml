<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- OmniAgent intentionally supports self-hosted LAN servers over HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
