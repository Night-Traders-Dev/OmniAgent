[Unit]
Description=OmniAgent AI Framework
After=network.target ollama.service

[Service]
Type=simple
User=kraken
WorkingDirectory=/home/kraken/Devel/OmniAgent
ExecStart=/home/kraken/Devel/OmniAgent/.venv/bin/uvicorn omni_agent:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
Environment=PATH=/home/kraken/Devel/OmniAgent/.venv/bin:/usr/local/bin:/usr/bin

[Install]
WantedBy=multi-user.target
